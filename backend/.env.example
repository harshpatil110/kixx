# Server Configuration
PORT=5000

# Database Configuration (Neon DB / PostgreSQL)
# Required connection string for Drizzle ORM
DATABASE_URL="postgresql://user:password@endpoint.neon.tech/neondb?sslmode=require"

# Firebase Admin Service Account Configuration
# Obtain this from Firebase Console -> Project Settings -> Service Accounts -> Generate New Private Key
# The private key MUST be in a single string format with \n representing newlines
FIREBASE_PROJECT_ID="your-project-id"
FIREBASE_CLIENT_EMAIL="firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com"
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour\nSuper\nLong\nPrivate\nKey\nLine\nBy\nLine\n-----END PRIVATE KEY-----\n"
